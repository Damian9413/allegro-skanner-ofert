{
  "manifest_version": 3,
  "name": "Allegro Skan Ofert - Wersja Zintegrowana",
  "version": "3.7.8",
  "description": "Skanuje oferty Allegro z autoryzacj\u0105 i limitem raport\u00f3w przez Google Sheets API",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://allegro.pl/*",
    "https://*.allegro.pl/*",
    "https://script.google.com/*",
    "https://dajstrone.pl/*",
    "https://unpkg.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://allegro.pl/*",
        "https://*.allegro.pl/*"
      ],
      "js": [
        "tesseract.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Allegro Skan Ofert"
  }
}